# Copy to .env on the prod host (or generate in CI from secrets). No real secrets in this file.

# ── Gateway ──────────────────────────────────────────────────────────────
EXTERNAL_HTTP_PORT=80     # must be 80 on the public host: Let's Encrypt HTTP-01
EXTERNAL_HTTPS_PORT=443
EXTERNAL_POSTGRES_PORT=5432

# Public hostname to serve TLS for. Empty = plain HTTP. Enabling it takes a
# one-off `certbot certonly` run; see docs/tls.md.
CERT_DOMAIN=chatbotportal.opdc.ai.in.th
CERT_EMAIL=                 # renewal-expiry notices from Let's Encrypt

# ── Environment ──────────────────────────────────────────────────────────
ENV=production            # triggers assert_production_secrets (JWT_SECRET must change)

# ── Database ─────────────────────────────────────────────────────────────
POSTGRES_DB=chatbot
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=          # set a strong value in prod

# ── Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=                 # python -c "import secrets; print(secrets.token_hex(32))"

# ── CORS / URLs (no IPs in source) ───────────────────────────────────────
CORS_ORIGINS=["https://your-prod-host"]
FRONTEND_BASE_URL=https://your-prod-host

# ── External services ────────────────────────────────────────────────────
ONECHAT_V3_URL=
ONECHAT_V4_URL=
ONECHAT_V5_URL=
# Upstream for POST /api/v1/chat/stream: "v5" (default) or "v4" (rollback)
CHAT_STREAM_VERSION=v5
MCP_ENDPOINT_URL=

# ── LLM ──────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=         # rotate the previously-committed key
