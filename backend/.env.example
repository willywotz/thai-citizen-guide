# Database (Supabase Postgres direct connection)
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_ID:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# Supabase
SUPABASE_URL=https://PROJECT_ID.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret   # from Dashboard > Settings > API > JWT Secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Gateway (OpenAI-compatible)
AI_GATEWAY_URL=https://ai.gateway.lovable.dev/v1
AI_GATEWAY_KEY=your-lovable-api-key
AI_MODEL=google/gemini-3-flash-preview

# App
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
