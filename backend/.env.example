# Copy this file to .env and fill in your values

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="AI Chatbot Portal API"
APP_VERSION="1.0.0"
DEBUG=false

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Format: postgres://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgres://postgres:postgres@localhost:5432/chatbot

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (JSON array format)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

PARSE_SPEC_URL="http://thaillm.or.th/api/openthaigpt/v1/chat/completions"
PARSE_SPEC_API_KEY=""
PARSE_SPEC_TIMEOUT=60
PARSE_SPEC_LLM_MODEL="/model"
